# =============================================================
# AI Provider Configuration
# =============================================================
# AI Provider: "mock" (default, no credentials needed) | "watsonx" |
# "openai" | "anthropic" | "gemini" | "openrouter" | "bedrock" |
# "ollama" | "lm-studio"
AI_PROVIDER=mock

# IBM watsonx.ai (required when AI_PROVIDER=watsonx)
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_REGION=us-south
WATSONX_MODEL_ID=ibm/granite-4-h-small

# =============================================================
# SECURITY — REQUIRED FOR PRODUCTION DEPLOYMENTS
# =============================================================
# By default, /api/ai/* routes are UNAUTHENTICATED. Any caller
# can request data for any customerId. This is acceptable for
# demos with mock data, but NOT for real customer data.
#
# To enable secure-by-default mode:
#   AI_ROUTE_AUTH_ENABLED=true
#
# Then provide API keys with tenant scoping:
#   AI_ROUTE_API_KEYS_JSON=[{"id":"team-1","token":"<secret>","allowedCustomers":["cust-001"],"requestsPerMinute":60}]
#
# When AI_ROUTE_AUTH_ENABLED is unset/false AND no API keys are
# configured, a security warning is logged at server startup.
# =============================================================
# AI_ROUTE_AUTH_ENABLED=true
# AI_ROUTE_API_KEYS_JSON=[{"id":"ops-team","token":"replace-me","allowedCustomers":["cust-001"],"requestsPerMinute":60}]
